# ── App ──────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-before-production

# ── Database ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/sellerbot

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Meta / Instagram ──────────────────────────────────────────────────
META_APP_ID=3068313716692836
META_APP_SECRET=2881b493cc17e8d082f0015efa34ace7
META_VERIFY_TOKEN=change-me-verify-token
META_API_VERSION=v19.0

# ── AI ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-key-here
SARVAM_API_KEY=

# ── AWS / S3 ──────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=sellerbot-uploads

# ── WhatsApp ──────────────────────────────────────────────────────────
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# ── Google ────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=

# ── JWT ───────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

